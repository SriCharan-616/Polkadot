{
    "name": "private-dao-voting",
    "version": "1.0.0",
    "description": "Private DAO voting system on Polkadot PVM with ElGamal encryption and ZK proofs",
    "main": "index.js",
    "scripts": {
        "deploy": "hardhat run scripts/deploy.js --network paseoAssetHub",
        "deploy:local": "hardhat run scripts/deploy.js --network hardhat",
        "keyholder": "node scripts/keyholder.js",
        "test": "hardhat test",
        "frontend": "cd frontend && npm start",
        "install:all": "npm install && cd frontend && npm install"
    },
    "keywords": [
        "voting",
        "privacy",
        "homomorphic-encryption",
        "zero-knowledge-proofs",
        "polkadot",
        "dao"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@nomicfoundation/hardhat-ethers": "^3.0.0",
        "hardhat": "^2.17.0"
    },
    "dependencies": {
        "ethers": "^6.4.0",
        "dotenv": "^16.0.3",
        "circomlibjs": "^0.1.7",
        "snarkjs": "^0.7.0"
    }
}
